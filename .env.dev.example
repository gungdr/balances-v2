POSTGRES_USER=balances
POSTGRES_PASSWORD=balances
POSTGRES_DB=balances
POSTGRES_PORT=5432

MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# Backend
DATABASE_URL=postgres://balances:balances@localhost:5432/balances?sslmode=disable
PORT=8080
LOG_FORMAT=text
# Advanced / rarely changed in dev:
# WEB_DIR — serve the built SPA from this dir (single-origin prod, ADR-0030).
#   Unset in dev: Vite serves the SPA and proxies /api to PORT.
# WEB_DIR=
# SHUTDOWN_TIMEOUT — grace period for in-flight requests on shutdown (default 10s).
# SHUTDOWN_TIMEOUT=10s
# HTTP_READ_TIMEOUT / HTTP_WRITE_TIMEOUT / HTTP_IDLE_TIMEOUT — bound a slow-body
# client, the largest legit response (backup export/restore), and an idle
# keep-alive connection. Defaults 30s/60s/120s.
# HTTP_READ_TIMEOUT=30s
# HTTP_WRITE_TIMEOUT=60s
# HTTP_IDLE_TIMEOUT=120s
# DB_MAX_CONNS / DB_STATEMENT_TIMEOUT — pgxpool size ceiling and a server-side
# per-connection query abort. Defaults 10 / 30s.
# DB_MAX_CONNS=10
# DB_STATEMENT_TIMEOUT=30s

# Auth (fill in from your Google Cloud OAuth client; see ADR-0017)
# Sign-in providers (ADR-0039). Defaults are Google-on, local-off; uncomment to
# exercise local email+password in dev. AUTH_LOCAL_ENABLED=true + a registered
# founder lets you sign in without a Google client; set AUTH_GOOGLE_ENABLED=false
# to drop Google entirely. The server refuses to start if both are disabled.
# AUTH_GOOGLE_ENABLED=true
# AUTH_LOCAL_ENABLED=false
# FOUNDING_DISABLED — stop the instance from founding any *new* household
# (#302), the next hardening layer after founding your dev household. Default
# false; leave unset in dev.
# FOUNDING_DISABLED=false
# DEMO_MODE (ADR-0041, #217) — the public-demo posture: blocks household
# Erasure, exposes DEMO_EMAIL/DEMO_PASSWORD on /api/auth/methods so the
# sign-in form pre-fills them, and mounts POST /admin/demo-reset. Only ever
# set on the hosted demo environment, never in self-host — leave unset in
# dev unless you're exercising this feature locally. Requires
# DEMO_RESET_TOKEN to be non-empty (the server refuses to start otherwise).
# DEMO_MODE=false
# DEMO_RESET_TOKEN=
# DEMO_EMAIL=demo@balances.local
# DEMO_PASSWORD=BalancesDemo!2026
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OIDC issuer for discovery; defaults to Google. Only overridden to point at the
# local mock-oidc provider for E2E (ADR-0024) — leave unset for normal dev.
# OIDC_ISSUER_URL=https://accounts.google.com
# Single-origin self-host (ADR-0037): set APP_URL alone and the three vars below
# derive from it — FRONTEND_URL/BACKEND_URL = APP_URL, OAUTH_REDIRECT_URL =
# APP_URL + /api/auth/google/callback. Any var set explicitly still overrides.
# APP_URL=https://balances.example.com
# Split-origin dev (Vite SPA + proxied /api) sets them individually instead:
OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080
SESSION_TTL=720h
COOKIE_SECURE=false

# Email (dev defaults point at Mailpit; SMTP_USERNAME/PASSWORD empty for Mailpit)
# Self-host (ADR-0037): EMAIL_ENABLED=false runs with no mail dependency — the
# mailer becomes a no-op, SMTP config below is unneeded, and invitations fall back
# to the "copy invite link" button. Default true keeps the SMTP wiring above.
# EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@balances.local
