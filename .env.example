# Self-host operator config (ADR-0037, #227). Copy to .env, edit, then:
#   docker compose up          # localhost trial → http://localhost:8080
# See SELF-HOSTING.md for the full walkthrough (incl. the Google OAuth client).

# Released image tag to run. No `latest` is published — pin a real release tag.
# Upgrade by bumping this and running `docker compose pull && docker compose up -d`.
BALANCES_TAG=v1.0.0

# Host port the app's single origin (SPA + /api) is published on.
APP_PORT=8080

# The one origin the app is reached on. APP_URL alone derives FRONTEND_URL,
# BACKEND_URL and the OAuth callback (<APP_URL>/api/auth/google/callback), so
# there is nothing else to keep in sync. Localhost-trial default below; for a
# real deployment set https://your-domain and flip COOKIE_SECURE=true.
APP_URL=http://localhost:8080
COOKIE_SECURE=false
SESSION_TTL=720h

# Postgres (the bundled `postgres` service). Change the password for anything
# beyond a localhost trial. DATABASE_URL is assembled by docker-compose.yml
# from these — you do not set it here.
POSTGRES_USER=balances
POSTGRES_PASSWORD=balances
POSTGRES_DB=balances

# Google OAuth client — the one manual step (sign-in is Google-only, ADR-0017).
# Create one in Google Cloud and set the authorised redirect URI to
# <APP_URL>/api/auth/google/callback. See SELF-HOSTING.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email. Default off: no mail dependency — invitations fall back to a
# "copy invite link" button; welcome/restore mails silently no-op (ADR-0037).
# To enable, set EMAIL_ENABLED=true and either point SMTP_* at your relay or
# bring up the bundled Mailpit sink: `docker compose --profile mail up`.
EMAIL_ENABLED=false
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM_ADDRESS=noreply@balances.local
# MAILPIT_SMTP_PORT=1025
# MAILPIT_HTTP_PORT=8025

LOG_FORMAT=json
