POSTGRES_USER=balances
POSTGRES_PASSWORD=balances
POSTGRES_DB=balances
POSTGRES_PORT=5432

MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# Backend
DATABASE_URL=postgres://balances:balances@localhost:5432/balances?sslmode=disable
PORT=8080
LOG_FORMAT=text

# Auth (fill in from your Google Cloud OAuth client; see ADR-0017)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080
SESSION_TTL=720h
COOKIE_SECURE=false

# Email (dev defaults point at Mailpit; SMTP_USERNAME/PASSWORD empty for Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@balances.local
